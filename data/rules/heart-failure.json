{
  "id": "heart-failure",
  "name": "Heart Failure",
  "subtypes": [
    {
      "id": "hfref",
      "name": "HFrEF (EF ≤ 40%)",
      "rules": {
        "discharge_eligible": {
          "all": [
            { "field": "stable_diuretics", "equals": true, "severity": "strict", "reason": "Must be stable on oral diuretics for ≥ 24h" },
            { "field": "on_sglt2i", "equals": true, "severity": "strict", "reason": "SGLT2i initiation is a 2024 Class 1 mandate" },
            { "field": "on_mra", "equals": true, "severity": "strict", "reason": "MRA is a mandatory GDMT pillar" },
            { "or": [{ "field": "on_raasi", "in": ["arni_target", "acei_arb_target"] }, { "field": "on_raasi", "equals": "contraindicated" }], "reason": "RAASi optimized or contraindicated" }
          ]
        },
        "followup_interval": {
          "rules": [
            { "if": { "field": "hospitalization_recent", "equals": true, "and": { "field": "months_since_hosp", "lt": 1 } }, "days": 7, "reason": "7-day safety check for recent hospitalization" },
            { "if": { "or": [{ "field": "on_raasi", "in": ["arni_uptitrating", "acei_arb_uptitrating"] }, { "field": "on_bb", "equals": "uptitrating" }] }, "weeks": 4 },
            { "default": 6 }
          ]
        }
      }
    }
  ]
}
