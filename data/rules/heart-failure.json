{
  "id": "heart-failure",
  "name": "Heart Failure",
  "subtypes": [
    {
      "id": "hfref",
      "name": "HFrEF (EF ≤ 40%)",
      "description": "Heart failure with reduced ejection fraction",
      "sections": [
        {
          "id": "severity",
          "title": "Disease Severity",
          "questions": [
            {
              "id": "ef_current",
              "label": "Most recent LVEF (%)",
              "type": "number",
              "min": 5,
              "max": 80,
              "step": 1,
              "required": true
            },
            {
              "id": "nyha_class",
              "label": "Current NYHA Functional Class",
              "type": "select",
              "options": [
                { "value": "I", "label": "Class I — No limitation" },
                { "value": "II", "label": "Class II — Slight limitation" },
                { "value": "III", "label": "Class III — Marked limitation" },
                { "value": "IV", "label": "Class IV — Symptoms at rest" }
              ],
              "required": true
            },
            {
              "id": "acc_stage",
              "label": "ACC/AHA Stage",
              "type": "select",
              "options": [
                { "value": "B", "label": "Stage B — Structural disease, no symptoms" },
                { "value": "C", "label": "Stage C — Structural disease with symptoms" },
                { "value": "D", "label": "Stage D — Advanced / Refractory" }
              ],
              "required": true
            }
          ]
        },
        {
          "id": "stability",
          "title": "Clinical Stability",
          "questions": [
            {
              "id": "symptoms_stable",
              "label": "Symptoms stable for ≥ 3 months?",
              "type": "boolean",
              "required": true
            },
            {
              "id": "hospitalization_recent",
              "label": "HF hospitalization in last 12 months?",
              "type": "boolean",
              "required": true
            },
            {
              "id": "months_since_hosp",
              "label": "Months since last HF hospitalization",
              "type": "number",
              "min": 0,
              "max": 60,
              "condition": { "field": "hospitalization_recent", "equals": true }
            },
            {
              "id": "weight_stable",
              "label": "Weight stable (no >2 kg change in 1 week)?",
              "type": "boolean"
            },
            {
              "id": "ef_trend",
              "label": "EF trend over last 1–2 years",
              "type": "select",
              "options": [
                { "value": "improving", "label": "Improving" },
                { "value": "stable", "label": "Stable" },
                { "value": "declining", "label": "Declining" }
              ]
            },
            {
              "id": "bnp_trend",
              "label": "BNP / NT-proBNP trend",
              "type": "select",
              "options": [
                { "value": "normal", "label": "Normal or near-normal" },
                { "value": "stable_elevated", "label": "Stable but elevated" },
                { "value": "rising", "label": "Rising" }
              ]
            }
          ]
        },
        {
          "id": "gdmt",
          "title": "Guideline-Directed Medical Therapy",
          "questions": [
            {
              "id": "on_raasi",
              "label": "RAASi (ACEi / ARB / ARNI) status",
              "type": "select",
              "options": [
                { "value": "arni_target", "label": "ARNI at target dose" },
                { "value": "arni_uptitrating", "label": "ARNI — uptitrating" },
                { "value": "acei_arb_target", "label": "ACEi/ARB at target dose" },
                { "value": "acei_arb_uptitrating", "label": "ACEi/ARB — uptitrating" },
                { "value": "none", "label": "Not on RAASi" },
                { "value": "contraindicated", "label": "Contraindicated" }
              ]
            },
            {
              "id": "on_bb",
              "label": "Evidence-based beta-blocker status",
              "type": "select",
              "options": [
                { "value": "target", "label": "At target dose" },
                { "value": "uptitrating", "label": "Uptitrating" },
                { "value": "none", "label": "Not on BB" },
                { "value": "contraindicated", "label": "Contraindicated" }
              ]
            },
            {
              "id": "on_mra",
              "label": "On MRA (spironolactone / eplerenone)?",
              "type": "boolean"
            },
            {
              "id": "on_sglt2i",
              "label": "On SGLT2 inhibitor?",
              "type": "boolean"
            }
          ]
        },
        {
          "id": "devices",
          "title": "Devices & Procedures",
          "questions": [
            {
              "id": "icd_indicated",
              "label": "ICD indicated and addressed?",
              "type": "select",
              "options": [
                { "value": "has_icd", "label": "ICD / CRT-D in place" },
                { "value": "not_indicated", "label": "Not indicated (EF recovered)" },
                { "value": "declined", "label": "Patient declined" },
                { "value": "pending", "label": "Pending evaluation" }
              ]
            },
            {
              "id": "device_check_current",
              "label": "Device interrogation current (< 6 months)?",
              "type": "boolean",
              "condition": { "field": "icd_indicated", "equals": "has_icd" }
            },
            {
              "id": "has_crt",
              "label": "CRT (biventricular pacing) in place?",
              "type": "boolean"
            }
          ]
        }
      ],
      "rules": {
        "discharge_eligible": {
          "description": "All must be true for safe discharge",
          "all": [
            { "field": "ef_current", "gte": 40, "reason": "LVEF has recovered to ≥ 40%" },
            { "field": "nyha_class", "in": ["I", "II"], "reason": "NYHA Class I or II" },
            { "field": "acc_stage", "not_equals": "D", "reason": "Not Stage D (advanced) heart failure" },
            { "field": "symptoms_stable", "equals": true, "reason": "Symptoms stable ≥ 3 months" },
            { "field": "hospitalization_recent", "equals": false, "reason": "No HF hospitalization in past 12 months" },
            { "field": "ef_trend", "in": ["improving", "stable"], "reason": "EF trend stable or improving" },
            {
              "or": [
                { "field": "on_raasi", "in": ["arni_target", "acei_arb_target"] },
                { "field": "on_raasi", "equals": "contraindicated" }
              ],
              "reason": "RAASi optimized or contraindicated"
            },
            {
              "or": [
                { "field": "on_bb", "in": ["target"] },
                { "field": "on_bb", "equals": "contraindicated" }
              ],
              "reason": "Beta-blocker optimized or contraindicated"
            },
            {
              "or": [
                { "field": "on_mra", "equals": true },
                { "field": "on_mra", "equals": false }
              ],
              "reason": "MRA status addressed"
            },
            {
              "or": [
                { "field": "on_sglt2i", "equals": true },
                { "field": "on_sglt2i", "equals": false }
              ],
              "reason": "SGLT2i status addressed"
            },
            {
              "or": [
                { "field": "icd_indicated", "in": ["has_icd", "not_indicated", "declined"] },
                { "field": "icd_indicated", "equals": "not_indicated" }
              ],
              "reason": "ICD indication addressed"
            }
          ]
        },
        "closer_followup": {
          "any": [
            { "field": "acc_stage", "equals": "D", "reason": "Stage D (advanced) heart failure requires specialized management" },
            { "field": "nyha_class", "in": ["III", "IV"], "reason": "NYHA Class III–IV symptoms indicate poor functional status" },
            { "field": "ef_current", "lt": 25, "reason": "Severely reduced EF (< 25%) warrants close monitoring" },
            { "field": "ef_trend", "equals": "declining", "reason": "Declining EF trajectory" },
            { "field": "bnp_trend", "equals": "rising", "reason": "Rising BNP/NT-proBNP suggests worsening HF" },
            { "field": "icd_indicated", "equals": "pending", "reason": "ICD evaluation still pending" }
          ]
        },
        "followup_interval": {
          "rules": [
            { "if": { "field": "acc_stage", "equals": "D" }, "months": 1 },
            { "if": { "field": "nyha_class", "in": ["III", "IV"] }, "months": 1 },
            { "if": { "field": "hospitalization_recent", "equals": true, "and": { "field": "months_since_hosp", "lt": 3 } }, "months": 1 },
            { "if": { "field": "ef_current", "lt": 25 }, "months": 2 },
            { "if": { "field": "ef_trend", "equals": "declining" }, "months": 2 },
            { "if": { "field": "bnp_trend", "equals": "rising" }, "months": 2 },
            { "if": { "or": [{ "field": "on_raasi", "in": ["arni_uptitrating", "acei_arb_uptitrating"] }, { "field": "on_bb", "equals": "uptitrating" }] }, "months": 3 },
            { "if": { "field": "hospitalization_recent", "equals": true }, "months": 3 },
            { "default": 6 }
          ]
        },
        "pcp_precautions": [
          {
            "condition": { "field": "ef_current", "lt": 55 },
            "text": "LVEF remains below normal. Return to cardiology if symptoms worsen, weight gain > 2 kg/week, new dyspnea, or edema."
          },
          {
            "condition": { "field": "icd_indicated", "equals": "has_icd" },
            "text": "Patient has ICD/CRT-D. Annual device checks required. Return urgently for ICD shocks, syncope, or device alerts."
          },
          {
            "condition": { "field": "on_mra", "equals": true },
            "text": "On aldosterone antagonist — monitor potassium and renal function every 3–6 months."
          },
          {
            "condition": { "field": "on_sglt2i", "equals": true },
            "text": "On SGLT2 inhibitor — monitor renal function and watch for genital mycotic infections, DKA symptoms."
          },
          {
            "text": "Continue all HF medications. Do not discontinue without cardiology consultation. Daily weights recommended."
          },
          {
            "text": "Repeat echocardiogram in 12 months if EF was previously reduced. Return to cardiology if EF declines or symptoms recur."
          }
        ]
      }
    },
    {
      "id": "hfpef",
      "name": "HFpEF (EF > 40%)",
      "description": "Heart failure with preserved ejection fraction",
      "sections": [
        {
          "id": "severity",
          "title": "Disease Severity",
          "questions": [
            {
              "id": "ef_current",
              "label": "Most recent LVEF (%)",
              "type": "number",
              "min": 30,
              "max": 80,
              "step": 1
            },
            {
              "id": "nyha_class",
              "label": "Current NYHA Functional Class",
              "type": "select",
              "options": [
                { "value": "I", "label": "Class I — No limitation" },
                { "value": "II", "label": "Class II — Slight limitation" },
                { "value": "III", "label": "Class III — Marked limitation" },
                { "value": "IV", "label": "Class IV — Symptoms at rest" }
              ]
            },
            {
              "id": "diastolic_dysfunction_grade",
              "label": "Diastolic dysfunction grade",
              "type": "select",
              "options": [
                { "value": "1", "label": "Grade I — Impaired relaxation" },
                { "value": "2", "label": "Grade II — Pseudonormal" },
                { "value": "3", "label": "Grade III — Restrictive" },
                { "value": "indeterminate", "label": "Indeterminate" }
              ]
            }
          ]
        },
        {
          "id": "stability",
          "title": "Clinical Stability",
          "questions": [
            {
              "id": "symptoms_stable",
              "label": "Symptoms stable for ≥ 3 months?",
              "type": "boolean"
            },
            {
              "id": "hospitalization_recent",
              "label": "HF hospitalization in last 12 months?",
              "type": "boolean"
            },
            {
              "id": "exercise_tolerance",
              "label": "Exercise tolerance",
              "type": "select",
              "options": [
                { "value": "good", "label": "Good — tolerates normal activities" },
                { "value": "moderate", "label": "Moderate — some limitation" },
                { "value": "poor", "label": "Poor — significant limitation" }
              ]
            }
          ]
        },
        {
          "id": "management",
          "title": "Management & Comorbidities",
          "questions": [
            {
              "id": "on_sglt2i",
              "label": "On SGLT2 inhibitor?",
              "type": "boolean"
            },
            {
              "id": "on_diuretic",
              "label": "On diuretic with stable dosing?",
              "type": "boolean"
            },
            {
              "id": "htn_controlled",
              "label": "Hypertension controlled?",
              "type": "boolean"
            },
            {
              "id": "af_managed",
              "label": "Atrial fibrillation (if present) managed?",
              "type": "select",
              "options": [
                { "value": "no_af", "label": "No AF" },
                { "value": "managed", "label": "AF — rate/rhythm controlled" },
                { "value": "uncontrolled", "label": "AF — not well controlled" }
              ]
            },
            {
              "id": "obesity_addressed",
              "label": "Obesity addressed (if BMI > 30)?",
              "type": "select",
              "options": [
                { "value": "not_obese", "label": "Not obese" },
                { "value": "addressed", "label": "Obese — weight management initiated" },
                { "value": "not_addressed", "label": "Obese — not yet addressed" }
              ]
            }
          ]
        }
      ],
      "rules": {
        "discharge_eligible": {
          "all": [
            { "field": "nyha_class", "in": ["I", "II"], "reason": "NYHA Class I or II" },
            { "field": "symptoms_stable", "equals": true, "reason": "Symptoms stable ≥ 3 months" },
            { "field": "hospitalization_recent", "equals": false, "reason": "No HF hospitalization in past 12 months" },
            { "field": "htn_controlled", "equals": true, "reason": "Hypertension controlled" },
            {
              "or": [
                { "field": "af_managed", "in": ["no_af", "managed"] }
              ],
              "reason": "Atrial fibrillation managed or absent"
            },
            { "field": "exercise_tolerance", "in": ["good", "moderate"], "reason": "Adequate exercise tolerance" }
          ]
        },
        "closer_followup": {
          "any": [
            { "field": "nyha_class", "in": ["III", "IV"], "reason": "NYHA Class III–IV symptoms" },
            { "field": "diastolic_dysfunction_grade", "equals": "3", "reason": "Grade III (restrictive) diastolic dysfunction" },
            { "field": "exercise_tolerance", "equals": "poor", "reason": "Poor exercise tolerance" },
            { "field": "af_managed", "equals": "uncontrolled", "reason": "Uncontrolled atrial fibrillation" }
          ]
        },
        "followup_interval": {
          "rules": [
            { "if": { "field": "nyha_class", "in": ["III", "IV"] }, "months": 2 },
            { "if": { "field": "hospitalization_recent", "equals": true }, "months": 3 },
            { "if": { "field": "af_managed", "equals": "uncontrolled" }, "months": 2 },
            { "default": 6 }
          ]
        },
        "pcp_precautions": [
          {
            "text": "HFpEF management focuses on comorbidity control: hypertension, obesity, atrial fibrillation, diabetes."
          },
          {
            "condition": { "field": "on_sglt2i", "equals": true },
            "text": "On SGLT2 inhibitor — monitor renal function. Evidence supports use in HFpEF."
          },
          {
            "text": "Return to cardiology if worsening dyspnea, new edema, or hospitalization for HF. Repeat echo if symptoms change."
          }
        ]
      }
    }
  ]
}
