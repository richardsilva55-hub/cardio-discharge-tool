{
  "id": "afib-flutter",
  "name": "AFib/Flutter",
  "rules": {
    "discharge_eligible": {
      "all": [
        { "field": "current_hr", "lt": 110, "severity": "strict", "reason": "Resting HR must be < 110 bpm" },
        { "field": "cha2ds2_vasc_assessed", "equals": true, "severity": "strict", "reason": "CHA2DS2-VASc documentation mandatory" },
        { "field": "on_anticoagulation", "equals": true, "severity": "strict", "reason": "Anticoagulation required for stroke prevention" },
        { "or": [{ "field": "obesity_addressed", "equals": "addressed" }, { "field": "obesity_addressed", "equals": "not_obese" }], "reason": "Class 1: Lifestyle modification must be initiated" }
      ]
    },
    "followup_interval": {
      "rules": [
        { "if": { "field": "ablation_months_ago", "lt": 3 }, "months": 3 },
        { "if": { "field": "current_hr", "gte": 100 }, "weeks": 4 },
        { "default": 6 }
      ]
    }
  }
}
