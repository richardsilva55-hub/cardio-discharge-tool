{
  "id": "valvular",
  "subtypes": [
    {
      "id": "aortic-stenosis",
      "rules": {
        "closer_followup": {
          "any": [
            { "field": "peak_velocity", "gte": 5, "reason": "Vmax ≥ 5 m/s (Very Severe AS) requires 3-month follow-up" },
            { "field": "ef_current", "lt": 50, "reason": "LVEF < 50% is a surgical trigger" }
          ]
        },
        "followup_interval": { "rules": [{ "if": { "field": "peak_velocity", "gte": 5 }, "months": 3 }, { "default": 12 }] }
      }
    },
    {
      "id": "aortic-regurgitation",
      "rules": {
        "discharge_eligible": {
          "all": [{ "field": "ef_current", "gte": 55, "severity": "strict", "reason": "LVEF threshold is 55% per 2020 Guidelines" }]
        }
      }
    }
  ]
}
