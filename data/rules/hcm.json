{
  "id": "hcm",
  "name": "Hypertrophic Cardiomyopathy",
  "subtypes": [
    {
      "id": "hcm",
      "name": "Hypertrophic Cardiomyopathy",
      "description": "HCM / HOCM evaluation and management",
      "sections": [
        {
          "id": "severity",
          "title": "Disease Severity",
          "questions": [
            { "id": "max_wall_thickness", "label": "Maximum wall thickness (mm)", "type": "number", "min": 10, "max": 40 },
            { "id": "lvot_gradient", "label": "LVOT gradient at rest (mmHg)", "type": "number", "min": 0, "max": 200 },
            { "id": "lvot_gradient_provoked", "label": "LVOT gradient with provocation (mmHg)", "type": "number", "min": 0, "max": 200 },
            { "id": "sam_present", "label": "SAM of mitral valve present?", "type": "boolean" },
            { "id": "la_size", "label": "Left atrial diameter (mm)", "type": "number", "min": 20, "max": 80 }
          ]
        },
        {
          "id": "scd_risk",
          "title": "Sudden Cardiac Death Risk Factors",
          "questions": [
            { "id": "family_hx_scd", "label": "Family history of SCD?", "type": "boolean" },
            { "id": "has_unexplained_syncope", "label": "Unexplained syncope?", "type": "boolean" },
            { "id": "has_nsvt", "label": "Non-sustained VT on Holter/monitor?", "type": "boolean" },
            { "id": "abnormal_bp_response", "label": "Abnormal BP response to exercise?", "type": "boolean" }
          ]
        },
        {
          "id": "symptoms",
          "title": "Symptoms & Function",
          "questions": [
            { "id": "nyha_class", "label": "NYHA Functional Class", "type": "select", "options": [
              { "value": "I", "label": "Class I — No limitation" },
              { "value": "II", "label": "Class II — Slight limitation" },
              { "value": "III", "label": "Class III — Marked limitation" },
              { "value": "IV", "label": "Class IV — Symptoms at rest" }
            ]},
            { "id": "has_angina", "label": "Chest pain / angina?", "type": "boolean" }
          ]
        },
        {
          "id": "treatment",
          "title": "Treatment & Screening",
          "questions": [
            { "id": "icd_status", "label": "ICD status", "type": "select", "options": [
              { "value": "has_icd", "label": "ICD in place" },
              { "value": "not_indicated", "label": "Not indicated" },
              { "value": "declined", "label": "Discussed — patient declined" },
              { "value": "pending", "label": "Evaluation pending" }
            ]},
            { "id": "septal_reduction", "label": "Septal reduction therapy?", "type": "select", "options": [
              { "value": "none", "label": "Not needed / not done" },
              { "value": "myectomy_done", "label": "Myectomy performed" },
              { "value": "asa_done", "label": "Alcohol septal ablation performed" },
              { "value": "planned", "label": "Planned" }
            ]},
            { "id": "on_mavacamten", "label": "On mavacamten (or other cardiac myosin inhibitor)?", "type": "boolean" },
            { "id": "family_screening_done", "label": "First-degree relatives screened?", "type": "boolean" },
            { "id": "genetic_testing_done", "label": "Genetic testing performed?", "type": "boolean" }
          ]
        }
      ],
      "rules": {
        "discharge_eligible": {
          "all": [
            { "field": "nyha_class", "in": ["I"], "reason": "Asymptomatic (NYHA Class I)" },
            { "field": "has_unexplained_syncope", "equals": false, "reason": "No unexplained syncope" },
            { "field": "family_hx_scd", "equals": false, "reason": "No family history of SCD" },
            { "field": "has_nsvt", "equals": false, "reason": "No NSVT on monitoring" },
            { "field": "max_wall_thickness", "lt": 30, "reason": "Wall thickness < 30mm" },
            { "or": [
              { "field": "icd_status", "in": ["has_icd", "not_indicated", "declined"] }
            ], "reason": "ICD indication addressed" },
            { "field": "septal_reduction", "in": ["none", "myectomy_done", "asa_done"], "reason": "No pending septal reduction" },
            { "field": "family_screening_done", "equals": true, "reason": "Family screening completed" },
            { "field": "on_mavacamten", "equals": false, "reason": "Not on cardiac myosin inhibitor (requires specialized monitoring)" }
          ]
        },
        "closer_followup": {
          "any": [
            { "field": "nyha_class", "in": ["III", "IV"], "reason": "NYHA Class III–IV symptoms" },
            { "field": "has_unexplained_syncope", "equals": true, "reason": "Unexplained syncope — high SCD risk" },
            { "field": "max_wall_thickness", "gte": 30, "reason": "Massive hypertrophy (≥ 30mm) — high SCD risk" },
            { "field": "icd_status", "equals": "pending", "reason": "ICD evaluation pending" },
            { "field": "septal_reduction", "equals": "planned", "reason": "Septal reduction planned" },
            { "field": "on_mavacamten", "equals": true, "reason": "On mavacamten — requires periodic echo and monitoring" }
          ]
        },
        "followup_interval": {
          "rules": [
            { "if": { "field": "on_mavacamten", "equals": true }, "months": 3 },
            { "if": { "field": "septal_reduction", "equals": "planned" }, "months": 2 },
            { "if": { "field": "nyha_class", "in": ["III", "IV"] }, "months": 3 },
            { "if": { "field": "has_nsvt", "equals": true }, "months": 6 },
            { "default": 12 }
          ]
        },
        "pcp_precautions": [
          { "text": "Avoid dehydration and extreme exertion. No high-intensity competitive sports per ACC/AHA guidelines." },
          { "text": "Annual echocardiogram recommended to monitor wall thickness, gradient, and LV function." },
          { "text": "First-degree relatives should be screened with echo and ECG (every 3–5 years for adults, every 1–2 years for adolescents)." },
          { "text": "Return to cardiology for syncope, presyncope, new palpitations, worsening dyspnea, or chest pain." },
          { "condition": { "field": "icd_status", "equals": "has_icd" }, "text": "ICD in place — annual device checks required." },
          { "text": "Avoid vasodilators, high-dose diuretics, and drugs that increase obstruction if LVOT gradient is present." }
        ]
      }
    }
  ]
}
